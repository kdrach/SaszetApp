# .env.prod.example
# Copy this file to .env.prod and fill in real production values.
# NEVER commit .env.prod to version control!

# ── PostgreSQL (Application DB) ─────────────────────────────────────────────
POSTGRES_USER=saszetapp
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=saszetapp_db

# ── PostgreSQL (Keycloak DB) ────────────────────────────────────────────────
KEYCLOAK_USER=keycloak
KEYCLOAK_PASSWORD=change_me_strong_password
KEYCLOAK_DB=keycloak_db

# ── Keycloak Admin ──────────────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change_me_strong_admin_password

# ── Backend Encryption ──────────────────────────────────────────────────────
# Must be exactly 32 bytes (256-bit) for AES-256.
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=change_me_32_byte_encryption_key_here

# ── Production Domain ───────────────────────────────────────────────────────
DOMAIN=saszet.app

# ── Certbot / Let's Encrypt ─────────────────────────────────────────────────
CERTBOT_EMAIL=your-email@example.com

# ── Keycloak Hostname ───────────────────────────────────────────────────────
KC_HOSTNAME=auth.saszet.app

# ── SMTP (Email Verification) ───────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASSWORD=secret
SMTP_FROM=noreply@saszet.app
