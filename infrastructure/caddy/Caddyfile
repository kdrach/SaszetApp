# Caddyfile
# Automatic HTTPS for SaszetApp

# Global Options
{
    # Log format
    log {
        output stdout
        format console
    }
}

# 1. Main Application (PWA)
{$DOMAIN} {
    reverse_proxy frontend-mobile:80
}

# 2. Admin Panel (PWA)
admin.{$DOMAIN} {
    reverse_proxy frontend-admin:80
}

# 3. Backend API
api.{$DOMAIN} {
    reverse_proxy backend-api:8080
}

# 4. Keycloak Identity Provider
auth.{$DOMAIN} {
    # Keycloak requires specific headers for proxying and WebSockets (admin console).
    # Caddy sets X-Forwarded-For and X-Forwarded-Proto by default.
    reverse_proxy keycloak:8080 {
        header_up X-Forwarded-Proto {scheme}
        header_up X-Forwarded-Port 443
    }
}
