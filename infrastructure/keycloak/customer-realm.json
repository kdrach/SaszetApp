{
  "id": "petfood-customer-realm",
  "realm": "petfood-customer-realm",
  "enabled": true,
  "internationalizationEnabled": true,
  "supportedLocales": ["pl", "en"],
  "defaultLocale": "pl",
  "registrationAllowed": true,
  "verifyEmail": true,
  "loginTheme": "saszet-theme",
  "smtpServer": {
    "host": "${env.SMTP_HOST}",
    "port": "${env.SMTP_PORT}",
    "user": "${env.SMTP_USER}",
    "password": "${env.SMTP_PASSWORD}",
    "from": "${env.SMTP_FROM}"
  },
  "clients": [
    {
      "clientId": "saszetapp-pwa",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "redirectUris": [
        "${env.FRONTEND_URL}/*"
      ],
      "webOrigins": [
        "${env.FRONTEND_URL}"
      ]
    }
  ],
  "users": []
}
